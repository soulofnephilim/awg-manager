# Release infrastructure — contain repo host IP, SSH key paths, and
# upload targets. Kept local-only to avoid leaking to the public source
# mirror; prior incidents shipped publish-github-release.sh and
# build-singbox-naive.sh before history rewrite caught them.
scripts/release.sh
scripts/backfill-changelog.sh
scripts/build-singbox-naive.sh
scripts/build-singbox-binaries.sh
scripts/publish-github-release.sh

# Local debug helpers — used live to validate router iptables behaviour
# during P3 (singbox-router DNS fallthrough). Not part of the production
# package; the production logic lives in internal/singbox/router/.
scripts/test-awgm-dns-nopolicy.sh

# Local one-off diagnostic scripts (kept local; the reusable RCI template
# scripts/diag-rci-endpoints.sh stays tracked, so listed explicitly here
# rather than via a diag-*.sh glob).
scripts/diag-issue-136-peer-no.sh
scripts/diag-replace-handshake.sh
scripts/diag-singbox-router.sh
