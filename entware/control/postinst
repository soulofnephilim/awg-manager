#!/bin/sh

# NOTE: opkg (unlike dpkg) invokes postinst as `postinst configure` with no
# version argument — there is no way to distinguish upgrade from fresh
# install here. Upgrade detection via "$2" never worked; the unified message
# below covers both cases.

# Create directories. /var/run is system tmpfs (always present) and
# is the new PID-file location since the migration off persistent
# /opt/var/run; explicit mkdir is defensive against unusual mount layouts.
mkdir -p /opt/etc/awg-manager/tunnels
mkdir -p /var/run
mkdir -p /opt/var/log

# Set permissions
chmod 755 /opt/bin/awg-manager
chmod 755 /opt/sbin/awg
chmod 755 /opt/etc/init.d/S99awg-manager
for hook in iflayerchanged ifcreated ifdestroyed ifipchanged; do
    chmod 755 "/opt/etc/ndm/${hook}.d/50-awg-manager.sh" 2>/dev/null || true
done

# Clean up legacy files
rm -f /opt/etc/ndm/ifstatechanged.d/50-awg-manager.sh
rm -f /opt/var/log/awg-wan-hook.log
rm -f /opt/etc/init.d/S80awg-manager
rm -rf /opt/lib/modules/awg_proxy
rm -rf /opt/share/www/awg-manager

# Start awg-manager
START_OK=1
/opt/etc/init.d/S99awg-manager start || START_OK=0

# Wait a moment for settings to be initialized
sleep 2

# Get the port from settings.json (daemon persists actual port there).
# sed extracts the first "port": N match; the old `grep | tr -cd 0-9`
# concatenated digits from every matching line and broke on minified JSON.
PORT=$(sed -n 's/.*"port"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' \
    /opt/etc/awg-manager/settings.json 2>/dev/null | head -n 1)
[ -z "$PORT" ] && PORT="2222"

# Get LAN IP from br0 interface (Keenetic bridge) - for display to user
ROUTER_IP=""
if command -v ip >/dev/null 2>&1; then
    # Get IP from br0 (LAN bridge)
    ROUTER_IP=$(ip -4 addr show br0 2>/dev/null | grep -oE 'inet [0-9.]+' | awk '{print $2}')
fi
if [ -z "$ROUTER_IP" ] && command -v ifconfig >/dev/null 2>&1; then
    # Fallback to ifconfig
    ROUTER_IP=$(ifconfig br0 2>/dev/null | grep -oE 'inet (addr:)?[0-9.]+' | grep -oE '[0-9.]+')
fi
if [ -z "$ROUTER_IP" ]; then
    ROUTER_IP="<ROUTER-IP>"
fi

echo ""
if [ "$START_OK" = "1" ]; then
    echo "=========================================="
    echo "  AWG Manager installed successfully!"
    echo "=========================================="
    echo ""
    echo "  Web UI: http://${ROUTER_IP}:${PORT}"
else
    echo "=========================================="
    echo "  AWG Manager installed, but the service"
    echo "  FAILED to start. Check the log and run:"
    echo "    /opt/etc/init.d/S99awg-manager start"
    echo "=========================================="
fi
echo ""
echo "  Commands:"
echo "    /opt/etc/init.d/S99awg-manager {start|stop|restart|status}"
echo ""
